# ─────────────────────────────────────────────
#  Waitry Stock Reporter — Variables de entorno
# ─────────────────────────────────────────────

# Credenciales de Waitry (usuario de la webapp)
WAITRY_USER=tu_email@ejemplo.com
WAITRY_PASSWORD=tu_contraseña

# Nombre de tu local (aparece en el PDF y el email)
PLACE_NAME=Mi Cafetería

# Email(s) que recibirán el reporte (separados por coma)
EMAIL_RECIPIENTS=gerente@micafeteria.com,dueño@micafeteria.com

# ── Configuración SMTP ───────────────────────
# Gmail: smtp.gmail.com / 587
# Outlook: smtp.office365.com / 587
# SendGrid: smtp.sendgrid.net / 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reporte@micafeteria.com
SMTP_PASSWORD=xxxx_app_password_xxxx   # Para Gmail: usar App Password
EMAIL_FROM=Reportes Cafetería

# ── Opcional ─────────────────────────────────
# Umbral de alerta de stock bajo (default: 5)
LOW_STOCK_THRESHOLD=5

# Activar modo demo (no hace scraping, usa datos de ejemplo)
DEMO_MODE=false
